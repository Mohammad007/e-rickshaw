# Copy to .env and adjust for your environment.
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# Admin panel login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# SocketIO async mode.
#   'threading' -> local dev / Windows (default)
#   'eventlet'  -> production on Railway (matches the gunicorn eventlet worker)
SOCKETIO_ASYNC_MODE=threading

# When 1, /auth/send-otp returns the OTP in the response (no SMS gateway yet).
# Set to 0 in production once MSG91/Fast2SMS is wired up.
DEV_SHOW_OTP=1

# Optional: override the SQLite file path
# DATABASE=erickshaw.db

# Set automatically by Railway / most hosts. Only set locally to change the
# port used by `python app.py`.
# PORT=5000
